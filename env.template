# Copy this file to `.env` in the project root and fill in your own values.

# Google Drive folder IDs
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_PROCESSED_FOLDER_ID=

# Local download directory (relative or absolute path)
DOWNLOAD_DIR=downloads

# Supabase configuration
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# API keys (optional). Uncomment and set if using AI services.
GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO